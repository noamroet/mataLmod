# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=mataLmod
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=mataLmod

# ── Backend ─────────────────────────────────────────────────
# asyncpg driver required for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://mataLmod:change_me_in_prod@localhost:5432/mataLmod
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=sk-ant-...
SECRET_KEY=replace_with_32_random_bytes
ENVIRONMENT=development   # development | staging | production
CORS_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_32_random_bytes

# ── Scraper ──────────────────────────────────────────────────
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_MAX_RETRIES=3
ANOMALY_CHECKSUM_THRESHOLD=0.30
