# ── MaTaLmod Production Environment ─────────────────────────────────────────
#
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.
#
# Generate random secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase / Railway Postgres) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/mataLmod

# ── Redis (Railway Redis / Upstash) ──────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@HOST:PORT/0

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Backend security ──────────────────────────────────────────────────────────
# 32-byte random hex — used to sign JWT tokens
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS

# API key for /api/v1/admin/* endpoints
ADMIN_API_KEY=REPLACE_WITH_64_HEX_CHARS

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production

# Comma-separated list of allowed origins (no trailing slash)
# Must match exactly what the browser sends in the Origin header.
CORS_ORIGINS=https://mataLmod.vercel.app,https://matalmod.co.il

# ── Observability ─────────────────────────────────────────────────────────────
# Leave empty to disable Sentry error reporting
SENTRY_DSN=https://XXXX@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Frontend (Next.js — injected at build time on Vercel) ────────────────────
NEXT_PUBLIC_API_URL=https://api.matalmod.co.il
NEXTAUTH_URL=https://matalmod.co.il
NEXTAUTH_SECRET=REPLACE_WITH_64_HEX_CHARS

# Frontend Sentry (NEXT_PUBLIC_ prefix = exposed to browser bundle)
NEXT_PUBLIC_SENTRY_DSN=https://XXXX@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Scraper ───────────────────────────────────────────────────────────────────
# Minimum seconds between requests to any one institution's website
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_MAX_RETRIES=3
# Flag scrape as anomaly if >30% of field checksums change in one run
ANOMALY_CHECKSUM_THRESHOLD=0.30
